{
  "entities": {
    "User": {
      "title": "User",
      "description": "User profile with role-based access control.",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "name": { "type": "string" },
        "email": { "type": "string" },
        "role": { "type": "string", "enum": ["admin", "teacher", "student"] },
        "houseId": { "type": "string", "description": "Applicable for students" }
      },
      "required": ["uid", "name", "role"]
    },
    "House": {
      "title": "House",
      "description": "House details and current point totals.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "totalPoints": { "type": "number" },
        "rank": { "type": "number" },
        "lastUpdated": { "type": "number" }
      },
      "required": ["id", "name", "totalPoints", "rank"]
    },
    "PointLog": {
      "title": "Point Log",
      "description": "Historical log of point transactions.",
      "type": "object",
      "properties": {
        "houseId": { "type": "string" },
        "points": { "type": "number" },
        "reason": { "type": "string" },
        "category": { "type": "string" },
        "awardedBy": { "type": "string" },
        "awardedByUid": { "type": "string" },
        "role": { "type": "string" },
        "timestamp": { "type": "number" }
      },
      "required": ["houseId", "points", "reason", "awardedBy", "timestamp"]
    },
    "PointReason": {
      "title": "Point Reason",
      "description": "Configurable reasons and point values for awarding points.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "label": { "type": "string" },
        "points": { "type": "number" },
        "category": { "type": "string" }
      },
      "required": ["id", "label", "points", "category"]
    },
    "SystemConfig": {
      "title": "System Configuration",
      "description": "Global settings for the application.",
      "type": "object",
      "properties": {
        "academicYear": { "type": "string" },
        "lastResetAt": { "type": "number" },
        "resetBy": { "type": "string" }
      },
      "required": ["academicYear"]
    }
  },
  "firestore": {
    "system/config": {
      "schema": "SystemConfig",
      "description": "Global system settings."
    },
    "users/{userId}": {
      "schema": "User",
      "description": "Individual user records."
    },
    "houses/{houseId}": {
      "schema": "House",
      "description": "House point aggregations."
    },
    "pointsLog/{logId}": {
      "schema": "PointLog",
      "description": "Transaction logs for point changes."
    },
    "pointReasons/{reasonId}": {
      "schema": "PointReason",
      "description": "Configurable point reasons."
    }
  }
}
