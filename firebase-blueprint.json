{
  "entities": {
    "User": {
      "title": "User",
      "description": "User profile with role-based access control.",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "name": { "type": "string" },
        "email": { "type": "string" },
        "role": { "type": "string", "enum": ["admin", "teacher", "student"] },
        "houseId": { "type": "string", "description": "Applicable for students" },
        "points": { "type": "number", "description": "Current academic year points" },
        "grade": { "type": "string" },
        "section": { "type": "string" }
      },
      "required": ["uid", "name", "role"]
    },
    "AcademicYear": {
      "title": "Academic Year",
      "description": "Historical record of an academic year's performance.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "startDate": { "type": "number" },
        "endDate": { "type": "number" },
        "houseStats": { 
          "type": "object",
          "description": "Final points for each house in this year"
        }
      },
      "required": ["id", "name"]
    },
    "PointLog": {
      "title": "Point Log",
      "description": "Historical log of point transactions.",
      "type": "object",
      "properties": {
        "academicYear": { "type": "string" },
        "houseId": { "type": "string" },
        "points": { "type": "number" },
        "reason": { "type": "string" },
        "category": { "type": "string" },
        "awardedBy": { "type": "string" },
        "awardedByUid": { "type": "string" },
        "targetUid": { "type": "string" },
        "targetName": { "type": "string" },
        "role": { "type": "string" },
        "timestamp": { "type": "number" }
      },
      "required": ["academicYear", "houseId", "points", "reason", "awardedBy", "timestamp"]
    },
    "PointReason": {
      "title": "Point Reason",
      "description": "Configurable reasons and point values for awarding points.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "label": { "type": "string" },
        "points": { "type": "number" },
        "category": { "type": "string" }
      },
      "required": ["id", "label", "points", "category"]
    },
    "SystemConfig": {
      "title": "System Configuration",
      "description": "Global settings for the application.",
      "type": "object",
      "properties": {
        "academicYear": { "type": "string" },
        "lastResetAt": { "type": "number" },
        "resetBy": { "type": "string" }
      },
      "required": ["academicYear"]
    }
  },
  "firestore": {
    "system/config": {
      "schema": "SystemConfig",
      "description": "Global system settings."
    },
    "academicYears/{yearId}": {
      "schema": "AcademicYear",
      "description": "Yearly historical summaries."
    },
    "users/{userId}": {
      "schema": "User",
      "description": "Individual user records."
    },
    "houses/{houseId}": {
      "schema": "House",
      "description": "Current year house point aggregations."
    },
    "pointsLog/{logId}": {
      "schema": "PointLog",
      "description": "Transaction logs indexed by academic year."
    },
    "pointReasons/{reasonId}": {
      "schema": "PointReason",
      "description": "Configurable point reasons."
    }
  }
}
